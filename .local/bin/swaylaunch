#!/bin/bash

clear
read -p "> " cmd

[ -z "$cmd" ] && exit 0

base=$(echo "$cmd" | awk '{print $1}')
args=${cmd#"$base"}

if [[ "$cmd" =~ \.(jpg|jpeg|png|gif|webp)$ ]]; then
    swaymsg exec "swayimg $cmd"
    exit 0
fi

if command -v "$base" &> /dev/null; then
    swaymsg exec "$cmd"
    exit 0
fi

if distrobox-enter -n gui -- command -v "$base" &> /dev/null; then
    swaymsg exec "distrobox-enter -n gui -- $cmd"
    exit 0
fi

notify-send -u critical "Error" "Application '$cmd' wasn't found."
